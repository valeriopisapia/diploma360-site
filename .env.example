# Diploma360 — variabili d'ambiente per il form lead → Brevo
# Copia questo file in `.env.local` (gitignored) e compila i valori per lo sviluppo locale.
# In produzione (Firebase App Hosting) questi valori arrivano dai secret di Cloud Secret Manager
# (vedi apphosting.yaml), NON da questo file.

# Chiave API v3 di Brevo (SEGRETA — mai committare). Brevo → SMTP & API → API Keys.
BREVO_API_KEY=

# ID numerico della lista Brevo dove entrano i lead. Brevo → Contatti → Liste.
BREVO_LIST_ID=

# Brand attivo (selezionato a BUILD-time). Opzionale: se assente, default `diploma360`.
# Valori validi: diploma360 | lascuola360. In produzione arriva dal secret `BRAND`
# mappato su questa env in apphosting.yaml.
NEXT_PUBLIC_BRAND=
