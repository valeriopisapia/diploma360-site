{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/recupero-anni-scolastici-ancona",
      "destination": "/recupero-anni-ancona.html"
    },
    {
      "source": "/recupero-anni-scolastici-bari",
      "destination": "/recupero-anni-bari.html"
    },
    {
      "source": "/recupero-anni-scolastici-bergamo",
      "destination": "/recupero-anni-bergamo.html"
    },
    {
      "source": "/recupero-anni-scolastici-bologna",
      "destination": "/recupero-anni-bologna.html"
    },
    {
      "source": "/recupero-anni-scolastici-cagliari",
      "destination": "/recupero-anni-cagliari.html"
    },
    {
      "source": "/recupero-anni-scolastici-catania",
      "destination": "/recupero-anni-catania.html"
    },
    {
      "source": "/recupero-anni-scolastici-firenze",
      "destination": "/recupero-anni-firenze.html"
    },
    {
      "source": "/recupero-anni-scolastici-genova",
      "destination": "/recupero-anni-genova.html"
    },
    {
      "source": "/recupero-anni-scolastici-latina",
      "destination": "/recupero-anni-latina.html"
    },
    {
      "source": "/recupero-anni-scolastici-milano",
      "destination": "/recupero-anni-milano.html"
    },
    {
      "source": "/recupero-anni-scolastici-napoli",
      "destination": "/recupero-anni-napoli.html"
    },
    {
      "source": "/recupero-anni-scolastici-padova",
      "destination": "/recupero-anni-padova.html"
    },
    {
      "source": "/recupero-anni-scolastici-palermo",
      "destination": "/recupero-anni-palermo.html"
    },
    {
      "source": "/recupero-anni-scolastici-perugia",
      "destination": "/recupero-anni-perugia.html"
    },
    {
      "source": "/recupero-anni-scolastici-pescara",
      "destination": "/recupero-anni-pescara.html"
    },
    {
      "source": "/recupero-anni-scolastici-roma",
      "destination": "/recupero-anni-roma.html"
    },
    {
      "source": "/recupero-anni-scolastici-salerno",
      "destination": "/recupero-anni-salerno.html"
    },
    {
      "source": "/recupero-anni-scolastici-torino",
      "destination": "/recupero-anni-torino.html"
    },
    {
      "source": "/recupero-anni-scolastici-verona",
      "destination": "/recupero-anni-verona.html"
    },
    {
      "source": "/blog/recuperare-due-anni-in-uno",
      "destination": "/recuperare-due-anni-in-uno.html"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(.*).html",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets-vetrina/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}